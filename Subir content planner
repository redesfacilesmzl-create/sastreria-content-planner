function togglePhase(id){
  var el = document.getElementById(id);
  if(el) el.style.display = el.style.display==='none'?'block':'none';
}
function updatePhaseStatus(pubId, phase, val){
  var p = state.publications.find(function(x){return x.id===pubId;});
  if(p){ p.phases[phase].status = val; updateOverallStatus(p); }
}
function updatePhaseNotes(pubId, phase, val){
  var p = state.publications.find(function(x){return x.id===pubId;});
  if(p) p.phases[phase].notes = val;
}
function updatePhaseField(pubId, phase, field, val){
  var p = state.publications.find(function(x){return x.id===pubId;});
  if(p) p.phases[phase][field] = val;
}
function updateOverallStatus(p){
  var ss = ['planning','production','editing','publish'].map(function(ph){return p.phases[ph].status;});
  if(ss.every(function(s){return s==='done';})) p.status='done';
  else if(ss.some(function(s){return s==='inprogress'||s==='done';})) p.status='inprogress';
  else p.status='pending';
}
function addComment(pubId){
  var p = state.publications.find(function(x){return x.id===pubId;});
  var inp = document.getElementById('cmt-inp-'+pubId);
  if(!p||!inp||!inp.value.trim()) return;
  var cm = {author:'Admin', text:inp.value.trim(), date:getToday(), isAdmin:true};
  if(!p.phases.editing.comments) p.phases.editing.comments = [];
  p.phases.editing.comments.push(cm);
  var cont = document.getElementById('comments-'+pubId);
  if(cont) cont.innerHTML += '<div class="comment comment-admin"><div class="comment-meta">👑 Admin · '+cm.date+'</div><div class="comment-text">'+escHtml(cm.text)+'</div></div>';
  inp.value = '';
}

