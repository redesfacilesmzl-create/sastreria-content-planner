function updateMetric(pubId, field, val){
  var p = state.publications.find(function(x){return x.id===pubId;});
  if(p) p.metrics[field] = parseInt(val)||0;
  var tv = state.publications.reduce(function(a,p){return a+(parseInt(p.metrics.views)||0);},0);
  var tr = state.publications.reduce(function(a,p){return a+(parseInt(p.metrics.reach)||0);},0);
  var ti = state.publications.reduce(function(a,p){return a+(parseInt(p.metrics.interactions)||0);},0);
  var sv = document.getElementById('sv'); if(sv) sv.textContent = tv.toLocaleString();
  var sr = document.getElementById('sr'); if(sr) sr.textContent = tr.toLocaleString();
  var si = document.getElementById('si'); if(si) si.textContent = ti.toLocaleString();
}

function analyzeMetrics(pubId){
  var p = state.publications.find(function(x){return x.id===pubId;});
  if(!p) return;
  var resultDiv = document.getElementById('metrics-ai-result');
  resultDiv.innerHTML = '<div class="card" style="margin-top:16px"><div class="loading"><div class="spinner"></div> Analizando métricas de '+p.id+'...</div></div>';
  fetch('https://api.anthropic.com/v1/messages',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({
      model:'claude-sonnet-4-20250514',
      max_tokens:900,
      messages:[{role:'user', content:'Analiza estas métricas de contenido (7 días) y dame recomendaciones:\n'
        +'- Publicación: '+p.id+' ('+p.unit+')\n'
        +'- Guión: '+p.script+'\n'
        +'- Vistas: '+p.metrics.views+', Alcance: '+p.metrics.reach+', Interacciones: '+p.metrics.interactions+', Compartidos: '+p.metrics.shares+', Guardados: '+p.metrics.saves+'\n'
        +(state.aiContext.business?'- Negocio: '+state.aiContext.business+'\n':'')
        +'Dame: 1) Evaluación del desempeño, 2) Qué funcionó bien, 3) Oportunidades de mejora, 4) Sugerencias para el próximo contenido similar. En español, práctico y específico.'}]
    })
  }).then(function(r){return r.json();}).then(function(data){
    var text = (data.content&&data.content[0]&&data.content[0].text)||'Error al analizar.';
    resultDiv.innerHTML = '<div class="card" style="margin-top:16px;border-left:3px solid var(--orange)">'
      +'<div class="card-title">🤖 Análisis IA — '+p.id+'</div>'
      +'<div style="font-size:13px;line-height:1.7">'+text.replace(/\n/g,'<br>').replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')+'</div></div>';
  }).catch(function(){
    resultDiv.innerHTML = '<div class="card" style="margin-top:16px"><div style="color:#dc2626;font-size:13px">Error al conectar con la IA.</div></div>';
  });
}

function analyzeAllMetrics(){
  var resultDiv = document.getElementById('metrics-ai-result');
  resultDiv.innerHTML = '<div class="card" style="margin-top:16px"><div class="loading"><div class="spinner"></div> Realizando análisis global...</div></div>';
  var summary = state.publications.map(function(p){
    return p.id+'('+p.unit+'): vistas='+p.metrics.views+', alcance='+p.metrics.reach+', interacciones='+p.metrics.interactions+', compartidos='+p.metrics.shares+', guardados='+p.metrics.saves;
  }).join('\n');
  fetch('https://api.anthropic.com/v1/messages',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({
      model:'claude-sonnet-4-20250514',
      max_tokens:1000,
      messages:[{role:'user', content:'Analiza el desempeño global de estas publicaciones y dame una estrategia de mejora:\n'+summary
        +'\n'+(state.aiContext.business?'Negocio: '+state.aiContext.business+'\n':'')
        +'Unidades: '+state.units.join(', ')+'\n'
        +'Dame: 1) Qué unidad performa mejor, 2) Patrones de engagement, 3) Estrategia para el próximo mes, 4) Tipo de contenido a priorizar. En español, práctico y accionable.'}]
    })
  }).then(function(r){return r.json();}).then(function(data){
    var text = (data.content&&data.content[0]&&data.content[0].text)||'Error al analizar.';
    resultDiv.innerHTML = '<div class="card" style="margin-top:16px;border-left:3px solid var(--navy)">'
      +'<div class="card-title">🤖 Análisis global — Todas las publicaciones</div>'
      +'<div style="font-size:13px;line-height:1.7">'+text.replace(/\n/g,'<br>').replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')+'</div></div>';
  }).catch(function(){
    resultDiv.innerHTML = '<div class="card" style="margin-top:16px"><div style="color:#dc2626;font-size:13px">Error al conectar con la IA.</div></div>';
  });
}

/* ====== HELPERS ====== */
function unitClass(unit){
  var safe = unit ? unit.replace(/[^a-zA-ZÀ-ú]/g,'') : '';
  var known = ['Turismo','Merchandising','Educación','Gastronomía','Cultura'];
  return known.includes(unit) ? 'unit-'+unit : 'unit-default';
}
function statusClass(s){
  return {pending:'status-pending',inprogress:'status-inprogress',done:'status-done'}[s]||'status-pending';
}
function statusLabel(s){
  return {pending:'⏳ Pendiente',inprogress:'🔄 En proceso',done:'✅ Realizada'}[s]||s;
}
function closeModal(id){
  document.getElementById(id).style.display='none';
  renderView(state.currentView);
}

renderView('calendar');
