function quickPrompt(text){ document.getElementById('chat-inp').value=text; sendAI(); }

function sendAI(){
  var inp = document.getElementById('chat-inp');
  var msg = inp.value.trim();
  if(!msg) return;
  inp.value='';
  state.aiContext.messages.push({role:'user', content:msg});
  var chatArea = document.getElementById('chat-area');
  chatArea.innerHTML += '<div class="chat-msg user"><div class="chat-who">👤 Tú</div><div class="chat-bubble">'+escHtml(msg)+'</div></div>';
  chatArea.innerHTML += '<div class="chat-msg ai" id="ai-loading"><div class="chat-who">🤖 Asistente IA</div><div class="chat-bubble"><div class="loading"><div class="spinner"></div> Analizando...</div></div></div>';
  chatArea.scrollTop = chatArea.scrollHeight;

  var sysPrompt = 'Eres un experto en marketing de contenidos para La Sastrería Digital, una agencia digital.\n'
    +(state.aiContext.business?'Negocio: '+state.aiContext.business+'\n':'')
    +(state.aiContext.market?'Mercado objetivo: '+state.aiContext.market+'\n':'')
    +'Unidades de contenido activas: '+state.units.join(', ')+'.\n'
    +'Responde en español. Sé concreto, creativo y accionable. Usa listas cuando sea útil.';

  var history = state.aiContext.messages.slice(-8).map(function(m){return {role:m.role, content:m.content};});

  fetch('https://api.anthropic.com/v1/messages',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({
      model:'claude-sonnet-4-20250514',
      max_tokens:1000,
      system:sysPrompt,
      messages:history
    })
  }).then(function(r){return r.json();}).then(function(data){
    var text = (data.content&&data.content[0]&&data.content[0].text)||'Error al obtener respuesta.';
    state.aiContext.messages.push({role:'assistant', content:text});
    var loadEl = document.getElementById('ai-loading');
    if(loadEl) loadEl.outerHTML = '<div class="chat-msg ai"><div class="chat-who">🤖 Asistente IA</div><div class="chat-bubble">'+text.replace(/\n/g,'<br>').replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>')+'</div></div>';
    var ca = document.getElementById('chat-area');
    if(ca) ca.scrollTop = ca.scrollHeight;
  }).catch(function(){
    var loadEl = document.getElementById('ai-loading');
    if(loadEl) loadEl.outerHTML = '<div class="chat-msg ai"><div class="chat-who">🤖 Asistente IA</div><div class="chat-bubble" style="color:#dc2626">Error de conexión. Verifica tu conexión a internet.</div></div>';
  });
}

